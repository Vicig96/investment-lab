# Application
ENV=development
APP_NAME=investment-lab
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://investlab:investlab@localhost:5432/investlab
DATABASE_URL_SYNC=postgresql+psycopg2://investlab:investlab@localhost:5432/investlab

# PostgreSQL (used by docker-compose)
POSTGRES_DB=investlab
POSTGRES_USER=investlab
POSTGRES_PASSWORD=investlab
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Security
SECRET_KEY=changeme-use-a-long-random-string-in-production

# Logging
LOG_LEVEL=INFO
