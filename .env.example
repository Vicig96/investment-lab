# ──────────────────────────────────────────────────────────
# Investment Lab — environment configuration
# Copy this file to .env and edit as needed.
# ──────────────────────────────────────────────────────────

# Application
ENV=development
APP_NAME=investment-lab
DEBUG=false
LOG_LEVEL=INFO

# ── DATABASE ───────────────────────────────────────────────
# LOCAL DEV (default — no setup required, creates investlab.db in project root)
DATABASE_URL=sqlite+aiosqlite:///./investlab.db
DATABASE_URL_SYNC=sqlite:///./investlab.db

# POSTGRESQL (Docker or remote — uncomment to use instead of SQLite)
# DATABASE_URL=postgresql+asyncpg://investlab:investlab@localhost:5432/investlab
# DATABASE_URL_SYNC=postgresql+psycopg2://investlab:investlab@localhost:5432/investlab

# PostgreSQL credentials (only needed for Docker Compose)
POSTGRES_DB=investlab
POSTGRES_USER=investlab
POSTGRES_PASSWORD=investlab
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Security
SECRET_KEY=changeme-use-a-long-random-string-in-production
